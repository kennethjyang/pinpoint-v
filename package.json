{
  "name": "pinpoint-v",
  "version": "5.0.0-dev1",
  "private": true,
  "description": "A Quasar Project",
  "keywords": [
    "quasar",
    "quasar-app",
    "quasar-app-vite",
    "quasar-cli",
    "vite",
    "vue",
    "vuejs"
  ],
  "author": "Kenneth Yang <kjy@is88.com>",
  "type": "module",
  "scripts": {
    "lint": "oxfmt && oxlint --fix",
    "lint:check": "oxfmt --check && oxlint",
    "dev": "quasar dev",
    "build": "quasar build",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "testui": "vitest --ui",
    "postinstall": "quasar prepare --silent",
    "local-atlas": "serve -C ~/pinpoint_atlases/"
  },
  "dependencies": {
    "@babylonjs/core": "^9.17.1",
    "@babylonjs/loaders": "^9.17.1",
    "@quasar/extras": "^2.0.0",
    "@vueuse/core": "^14.3.0",
    "@vueuse/integrations": "^14.3.0",
    "axios": "^1.18.1",
    "fuse.js": "^7.5.0",
    "pinia": "^4.0.2",
    "pinia-plugin-persistedstate": "^4.7.1",
    "quasar": "^2.22.0",
    "semver": "^7.8.5",
    "vue": "^3.5.40",
    "vue-i18n": "^11.4.7",
    "vue-router": "^5.2.0"
  },
  "devDependencies": {
    "@intlify/unplugin-vue-i18n": "^11.0.0",
    "@quasar/app-vite": "^3.2.0",
    "@quasar/vite-plugin": "^1.12.0",
    "@testing-library/vue": "^8.1.0",
    "@types/node": "^26.1.1",
    "@types/semver": "^7.7.1",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "@vue/test-utils": "^2.4.11",
    "autoprefixer": "^10.5.4",
    "happy-dom": "^20.11.1",
    "lefthook": "^2.1.10",
    "oxfmt": "^0.x",
    "oxlint": "^1.x",
    "oxlint-tsgolint": "^7.x",
    "serve": "^14.2.6",
    "typescript": "6.0.3",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.8"
  },
  "engines": {
    "node": ">= 26 || ^24 || ^22.12"
  },
  "productName": "Pinpoint V"
}
